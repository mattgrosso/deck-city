{
  "name": "deck-city",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "deploy": "yarn build && aws s3 sync dist/ s3://$S3_BUCKET --profile personal-deploy --delete && aws cloudfront create-invalidation --distribution-id $CLOUDFRONT_DISTRIBUTION_ID --paths '/*' --profile personal-deploy"
  },
  "dependencies": {
    "phaser": "^3.80.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9",
    "eslint-plugin-promise": "^7",
    "eslint-plugin-vue": "^9",
    "globals": "^15",
    "jsdom": "^26.1.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
